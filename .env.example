# ════════════════════════════════════════════════════════════
#  .env.example  —  copy this file to .env for local dev
#  NEVER commit your real .env to Git
# ════════════════════════════════════════════════════════════

# ── Django ─────────────────────────────────────────────────
# Generate a key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-me-with-a-real-secret-key

# Which settings file to load
DJANGO_SETTINGS_MODULE=job_portal.settings.development

# ── Production only (leave blank for local dev) ────────────
# DATABASE_URL is set automatically by Railway/Render.
# For local Postgres: postgres://user:password@localhost:5432/HireHub
DATABASE_URL=

# Redis URL (Railway/Render set this automatically too)
REDIS_URL=redis://localhost:6379

# Comma-separated — add your Railway/Render domain here
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Email (optional — prints to console if left blank) ──────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
# Use a Gmail App Password, not your real password
# Guide: https://support.google.com/accounts/answer/185833
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=HireHub <noreply@yourdomain.com>

# ── Google OAuth (optional) ────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. APIs & Services → Credentials → Create OAuth 2.0 Client
# 3. Add redirect URI: https://yourdomain.com/accounts/google/login/callback/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
